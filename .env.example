# PostgreSQL Connection String (Yandex Cloud KZ / Local)
DATABASE_URL="postgresql://tenderai_user:tenderai_password@localhost:5432/tenderai_db?schema=public"

# Redis Queue Connection String (BullMQ)
REDIS_URL="redis://localhost:6379"

# Official Goszakup API Credentials (goszakup.gov.kz - ЕГСЗ РК)
GOSZAKUP_API_TOKEN="your_goszakup_api_bearer_token_here"
GOSZAKUP_API_URL="https://goszakup.gov.kz/api/v3/graphql"

# Samruk-Kazyna Portal API Credentials (portal.sk.kz)
SAMRUK_API_TOKEN="your_samruk_api_token_here"
SAMRUK_API_URL="https://portal.sk.kz/api/v1/tenders"

# LLM API Provider Keys (Google Gemini / OpenAI)
LLM_API_KEY="your_llm_api_key_here"
LLM_MODEL_NAME="gemini-1.5-flash"
EMBEDDING_MODEL_NAME="text-embedding-004"

# Telegram Bot Credentials (Telegraf)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_from_botfather"
TELEGRAM_BOT_USERNAME="TenderAI_KZ_bot"

# Kaspi Business & Kaspi Pay Webhook Integration
KASPI_PAY_API_KEY="your_kaspi_business_api_key_here"
KASPI_WEBHOOK_SECRET="your_kaspi_webhook_signature_secret"

# App Environment
NEXT_PUBLIC_APP_URL="http://localhost:3000"
