generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProcurementMethod {
  OPEN_TENDER        // Открытый конкурс
  AUCTION            // Аукцион
  PRICE_REQUEST      // Запрос ценовых предложений
  SINGLE_SOURCE      // Из одного источника
  TWO_STAGE_TENDER   // Двуэтапный конкурс
}

enum SourceType {
  GOSZAKUP           // goszakup.gov.kz
  SAMRUK_KAZYNA      // portal.sk.kz
  KAZATMROPROM       // e-procurement.kazatomprom.kz
  B2B_PRIVATE        // Частные b2b площадки
}

enum AdapterType {
  API                // Официальный API
  SCRAPER            // Парсинг страниц (fallback)
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum KanbanStage {
  UNDER_REVIEW       // На рассмотрении
  PREPARING_BID      // Готовим заявку
  SUBMITTED          // Подано
  WON                // Выиграли
  LOST               // Проиграли
}

enum TariffPlan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Tender {
  id                        String             @id @default(uuid())
  source                    SourceType
  externalId                String
  title                     String
  description               String?
  customerName              String
  customerBin               String
  category                  String
  industryTags              String[]
  procurementMethod         ProcurementMethod
  amount                    Float              // В KZT
  currency                  String             @default("KZT")
  region                    String
  publishDate               DateTime
  deadlineDate              DateTime
  applicationSecurityAmount Float?             // Обеспечение заявки KZT
  applicationSecurityPercent Float?            // Обеспечение %
  status                    String             @default("ACTIVE")
  sourceUrl                 String
  rawContent                String?            // Raw JSON or Text
  normalizedAt              DateTime           @default(now())

  // AI & Risk enrichment
  aiSummary                 String?
  aiKeyRequirements         String[]
  riskScore                 Int                @default(0) // 0 - 100
  riskFlags                 RiskFlag[]
  documents                 TenderDocument[]
  history                   TenderAuditTrail[]
  kanbanCards               KanbanCard[]

  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  @@unique([source, externalId])
  @@index([region])
  @@index([category])
  @@index([amount])
  @@index([deadlineDate])
}

model RiskFlag {
  id          String       @id @default(uuid())
  tenderId    String
  tender      Tender       @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  code        String       // e.g., SHORT_DEADLINE, CUSTOMER_CANCEL_HISTORY, UNUSUAL_REQS
  severity    RiskSeverity
  title       String
  description String
}

model TenderDocument {
  id        String   @id @default(uuid())
  tenderId  String
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileSize  String?
  fileType  String?
}

model TenderAuditTrail {
  id         String   @id @default(uuid())
  tenderId   String
  tender     Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  changedBy  String   @default("SYSTEM_PARSER")
  field      String
  oldValue   String?
  newValue   String?
  timestamp  DateTime @default(now())
}

model DataSource {
  id                String       @id @default(uuid())
  name              SourceType   @unique
  displayName       String
  adapterType       AdapterType  @default(API)
  isActive          Boolean      @default(true)
  checkIntervalMins Int          @default(15)
  lastSyncAt        DateTime?
  healthStatus      String       @default("HEALTHY") // HEALTHY, DEGRADED, DOWN
  successRate24h    Float        @default(99.8)
  totalIngested     Int          @default(0)
  logs              ConnectorLog[]
}

model ConnectorLog {
  id           String     @id @default(uuid())
  sourceId     String
  source       DataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  status       String     // SUCCESS, WARN, ERROR
  message      String
  itemsFetched Int        @default(0)
  durationMs   Int        @default(0)
  timestamp    DateTime   @default(now())
}

model AiTokenUsage {
  id               String   @id @default(uuid())
  userId           String?
  operationType    String   // EMBEDDING, SUMMARIZATION, RAG_QA, MATCHING
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  costKzt          Float
  modelName        String
  timestamp        DateTime @default(now())
}

model CompanyProfile {
  id           String   @id @default(uuid())
  companyName  String
  bin          String   @unique
  activities   String   // Описание видов деятельности на естественном языке
  keywords     String[]
  regions      String[]
  minAmount    Float    @default(0)
  maxAmount    Float?
  contactEmail String
  telegramChatId String?
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  fullName     String
  companyName  String?
  role         String          @default("USER") // USER, ADMIN
  tariffPlan   TariffPlan      @default(FREE)
  company      CompanyProfile?
  kanbanCards  KanbanCard[]
  subscriptions NotificationSetting[]
  payments     Payment[]
  createdAt    DateTime        @default(now())
}

model Payment {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentProvider String       @default("KASPI_PAY")
  externalTxId   String?       @unique
  amountKzt      Float
  plan           TariffPlan
  status         PaymentStatus @default(PENDING)
  qrCodeUrl      String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
}

model KanbanCard {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenderId    String
  tender      Tender      @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  stage       KanbanStage @default(UNDER_REVIEW)
  notes       String?
  assignee    String?
  priority    String      @default("MEDIUM") // LOW, MEDIUM, HIGH
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userId, tenderId])
}

model NotificationSetting {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filterQuery     String?  // Запрос поиска или ключевые слова
  regions         String[]
  categories      String[]
  minAmount       Float?
  maxAmount       Float?
  channelTelegram Boolean  @default(true)
  channelEmail    Boolean  @default(true)
  channelPush     Boolean  @default(true)
  frequency       String   @default("INSTANT") // INSTANT, DAILY_DIGEST
  createdAt       DateTime @default(now())
}
